@model Project
@{
    ViewData["Title"] = "Yeni Proje Oluştur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>Yeni Proje Oluştur</h2>
    <hr />

    <form method="post" action="/Admin/Project/CreateProject" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label fw-bold">Proje Adı</label>
            <input type="text" class="form-control" asp-for="Name" placeholder="Örn: E-Ticaret Portalı" required />
            <span class="text-danger" asp-validation-for="Name"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Proje Görseli</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" required />
            <small class="text-muted">Projeniz için bir ekran görüntüsü veya görsel seçiniz (.jpg, .png, .webp).</small>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">GitHub URL</label>
            <input type="url" class="form-control" asp-for="GithubUrl" placeholder="https://github.com/kullaniciadi/proje" />
            <span class="text-danger" asp-validation-for="GithubUrl"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Proje Açıklaması</label>
            <textarea class="form-control" asp-for="Description" rows="4" placeholder="Projede kullanılan teknolojiler ve işlevler hakkında bilgi verin..."></textarea>
            <span class="text-danger" asp-validation-for="Description"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <span class="material-symbols-outlined align-middle fs-6">save</span> Kaydet
            </button>
            <a href="/Admin/Project/Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>