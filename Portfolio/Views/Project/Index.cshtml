@model List<Project>
@{
    ViewData["Title"] = "Projelerim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<table class="table table-hover table table-bordered">
    <tr>

        <th>Proje Adı</th>
        <th>Açıklama</th>
        <th>Github Linki</th>
        <th>Görsel</th>
        <th>İşlemler</th>

    </tr>
    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Name</td>
                <td>@project.Description</td>
                <td> <a href="@project.GithubUrl" target="_blank" class="btn btn-outline-dark">Github Url</a></td>
                <td><img src="@project.ImageUrl" style="height:50px;width:50px" /></td>
                <td>
                    <button onclick="deleteProject(@project.Id)" class="btn btn-outline-danger">Sil</button>
                    <a href="/Admin/Project/UpdateProject/@project.Id" class="btn btn-outline-info">Güncelle</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="/Admin/Project/CreateProject/" class="btn btn-outline-dark">Yeni Proje Oluştur</a>

<script>
    function deleteProject(id){

            Swal.fire({
      title: "Silmek istediğinize emin misiniz?",
      text: "Bu işlemi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      confirmButtonText: "Evet, Sil!",
      cancelButtonText: "İptal",
      cancelButtonColor: "#d33",
    }).then((result) => {
      if (result.isConfirmed)
      window.location.href = "/Admin/Project/DeleteProject/"+id;
    });
    }
</script>