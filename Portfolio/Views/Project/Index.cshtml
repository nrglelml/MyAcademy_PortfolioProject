@model List<Project>
@{
    ViewData["Title"] = "Projelerim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Projelerim</h2>
        <a href="/Admin/Project/CreateProject/" class="btn btn-outline-dark">
            <span class="material-symbols-outlined align-middle fs-6">add</span> Yeni Proje Oluştur
        </a>
    </div>
    <hr />

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 80px;" class="text-center">Görsel</th>
                <th>Proje Adı</th>
                <th style="width: 35%;">Açıklama</th>
                <th style="width: 140px;" class="text-center">GitHub</th>
                <th style="width: 160px;" class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model)
            {
                <tr>
                    <td class="text-center">
                        @if (!string.IsNullOrEmpty(project.ImageUrl))
                        {
                            <img src="@project.ImageUrl" alt="@project.Name" class="rounded border" style="height: 50px; width: 50px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="badge bg-secondary">Görsel Yok</span>
                        }
                    </td>
                    <td class="fw-bold">@project.Name</td>
                    <td class="text-truncate" style="max-width: 300px;" title="@project.Description">@project.Description</td>
                    <td class="text-center">
                        @if (!string.IsNullOrEmpty(project.GithubUrl))
                        {
                            <a href="@project.GithubUrl" target="_blank" class="btn btn-outline-dark btn-sm">
                                Linke Git
                            </a>
                        }
                        else
                        {
                            <span class="text-muted fs-7">-</span>
                        }
                    </td>
                    <td class="text-center">
                        <a href="/Admin/Project/UpdateProject/@project.Id" class="btn btn-outline-info btn-sm">Güncelle</a>
                        <button onclick="deleteProject(@project.Id)" class="btn btn-outline-danger btn-sm">Sil</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function deleteProject(id) {
        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            confirmButtonText: "Evet, Sil!",
            cancelButtonText: "İptal",
            cancelButtonColor: "#d33",
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Project/DeleteProject/" + id;
            }
        });
    }
</script>