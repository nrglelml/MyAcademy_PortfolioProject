@model Project
@{
    ViewData["Title"] = "Proje Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>Proje Güncelle</h2>
    <hr />

    <form method="post" action="/Admin/Project/UpdateProject" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label fw-bold">Proje Adı</label>
            <input type="text" class="form-control" asp-for="Name" required />
            <span class="text-danger" asp-validation-for="Name"></span>
        </div>

        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
        {
            <div class="mb-3">
                <label class="form-label fw-bold d-block">Mevcut Görsel</label>
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail rounded" style="max-height: 150px; object-fit: cover;" />
            </div>
        }

        <div class="mb-3">
            <label class="form-label fw-bold">Görseli Değiştir (İsteğe Bağlı)</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
            <small class="text-muted">Yeni bir görsel seçmezseniz mevcut görseliniz korunacaktır.</small>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">GitHub URL</label>
            <input type="url" class="form-control" asp-for="GithubUrl" />
            <span class="text-danger" asp-validation-for="GithubUrl"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Proje Açıklaması</label>
            <textarea class="form-control" asp-for="Description" rows="4"></textarea>
            <span class="text-danger" asp-validation-for="Description"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-info text-white">
                <span class="material-symbols-outlined align-middle fs-6">sync</span> Güncelle
            </button>
            <a href="/Admin/Project/Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>