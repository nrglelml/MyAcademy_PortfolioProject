                      "on-error-container": "#ffdad6",
                      "background": "#121414",
                      "surface-bright": "#38393a",
                      "primary": "#dbfcff",
                      "error": "#ffb4ab",
                      "on-primary-fixed": "#002022",
                      "surface-dim": "#121414",
                      "on-tertiary-fixed-variant": "#474646",
                      "primary-fixed": "#7df4ff",
                      "surface-variant": "#333535",
                      "inverse-primary": "#006970",
