                      "tertiary-fixed-dim": "#c8c6c5",
                      "on-primary-fixed-variant": "#004f54",
                      "on-secondary": "#520071",
                      "surface-tint": "#00dbe9",
                      "on-background": "#e2e2e2",
                      "surface-container-highest": "#333535",
                      "on-primary-container": "#006970",
                      "on-surface-variant": "#b9cacb",
                      "surface-container": "#1e2020",
