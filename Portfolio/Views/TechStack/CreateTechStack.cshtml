@model TechStack
@{
    ViewData["Title"] = "Yeni Teknoloji Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Yeni Teknoloji Ekle</h4>
                </div>
                <div class="card-body">
                    <form method="post" action="/Admin/TechStack/CreateTechStack">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Teknoloji / Araç Adı</label>
                            <input type="text" class="form-control" asp-for="Name" placeholder="Örn: React, C#, PostgreSQL" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Kategori</label>
                            <select class="form-select" asp-for="Category" required>
                                <option value="" disabled selected>Lütfen bir kategori seçiniz...</option>
                                <option value="Frontend">Frontend</option>
                                <option value="Backend">Backend</option>
                                <option value="Database">Database</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <span class="material-symbols-outlined align-middle fs-6">save</span> Kaydet
                            </button>
                            <a href="/Admin/TechStack/" class="btn btn-outline-secondary">İptal</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>