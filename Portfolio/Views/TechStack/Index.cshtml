@model List<TechStack>
@{
    ViewData["Title"] = "Teknolojilerim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Teknoloji Listesi</h2>

        <div class="d-flex align-items-center gap-2">
            <label class="fw-bold me-1">Filtrele:</label>
            <select id="categoryFilter" class="form-select form-select-sm style="width: 180px;" onchange="filterCategory()">
                <option value="all">Tüm Kategoriler</option>
                <option value="Frontend">Frontend</option>
                <option value="Backend">Backend</option>
                <option value="Database">Database</option>
            </select>
        </div>
    </div>
    <hr />

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 30%;">İsim</th>
                <th style="width: 25%;" class="text-center">Kategori</th>
                <th style="width: 20%;" class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="tech-row" data-category="@item.Category">
                    <td class="fw-bold">@item.Name</td>

                    <td class="text-center">
                        @if (item.Category == "Frontend")
                        {
                            <span class="badge bg-info text-dark fs-6">Frontend</span>
                        }
                        else if (item.Category == "Backend")
                        {
                            <span class="badge bg-warning text-dark fs-6">Backend</span>
                        }
                        else if (item.Category == "Database")
                        {
                            <span class="badge bg-success fs-6">Database</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">@item.Category</span>
                        }
                    </td>

                    <td class="text-center">
                        <button onclick="deleteTechStack(@item.Id)" class="btn btn-outline-danger btn-sm">Sil</button>
                        <a href="/Admin/TechStack/UpdateTechStack/@item.Id" class="btn btn-outline-info btn-sm">Güncelle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a href="/Admin/TechStack/CreateTechStack" class="btn btn-outline-dark">
        <span class="material-symbols-outlined align-middle fs-6">add</span> Yeni Teknoloji Ekle
    </a>
</div>

<script>
    function filterCategory() {
        const selectedCategory = document.getElementById('categoryFilter').value;
        const rows = document.querySelectorAll('.tech-row');

        rows.forEach(row => {
            const category = row.getAttribute('data-category');
            if (selectedCategory === 'all' || category === selectedCategory) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    function deleteTechStack(id) {
        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            confirmButtonText: "Evet, Sil!",
            cancelButtonText: "İptal",
            cancelButtonColor: "#d33",
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/TechStack/DeleteTechStack/" + id;
            }
        });
    }
</script>