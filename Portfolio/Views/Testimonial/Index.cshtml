@model Testimonial
@{
    ViewData["Title"] = "Referans / Yorum Ekle";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<style>
    

    .tst-wrap {
        max-width: 760px;
        margin: 0 auto;
        padding: 64px 20px 96px;
    }

    .tst-card {
        background: rgba(255, 255, 255, 0.035);
        border: 1px solid rgba(255, 255, 255, 0.09);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-radius: 20px;
        padding: 44px;
        box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.6);
    }

    @@media (max-width: 640px) {
        .tst-card {
            padding: 28px 22px;
        }
    }

    .tst-header {
        text-align: center;
        margin-bottom: 36px;
        padding-bottom: 22px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .tst-title {
        color: #fff;
        font-weight: 700;
        font-size: 1.6rem;
        margin: 0 0 8px;
        letter-spacing: -0.01em;
    }

    .tst-subtitle {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.92rem;
        margin: 0;
    }

    /* Alert kutuları */
    .tst-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 24px;
        font-size: 0.92rem;
        position: relative;
    }

    .tst-alert-success {
        background: rgba(34, 197, 94, 0.12);
        border: 1px solid rgba(34, 197, 94, 0.35);
        color: #86efac;
    }

    .tst-alert-error {
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239, 68, 68, 0.35);
        color: #fca5a5;
    }

    .tst-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        color: inherit;
        opacity: 0.6;
        cursor: pointer;
        font-size: 1rem;
        line-height: 1;
    }

        .tst-alert-close:hover {
            opacity: 1;
        }

    /* Form grid: Bootstrap yerine kendi grid'imiz */
    .tst-form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    @@media (max-width: 640px) {
        .tst-form {
            grid-template-columns: 1fr;
        }
    }

    .tst-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .tst-field-full {
        grid-column: 1 / -1;
    }

    .tst-label {
        color: rgba(255, 255, 255, 0.62);
        font-weight: 500;
        font-size: 0.86rem;
    }

    .tst-required {
        color: #f87171;
        margin-left: 2px;
    }

    .tst-input,
    .tst-textarea {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #fff;
        border-radius: 10px;
        padding: 0.8rem 1rem;
        font-size: 0.95rem;
        font-family: inherit;
        transition: all 0.25s ease;
        width: 100%;
        box-sizing: border-box;
    }

    .tst-textarea {
        resize: vertical;
        min-height: 120px;
        line-height: 1.5;
    }

        .tst-input:focus,
        .tst-textarea:focus {
            background-color: rgba(255, 255, 255, 0.08);
            border-color: #a78bfa;
            box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.25);
            outline: none;
        }

        .tst-input::placeholder,
        .tst-textarea::placeholder {
            color: rgba(255, 255, 255, 0.32);
        }

    /* Yıldız puanlama - erişilebilir radio grubu */
    .tst-rating-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
    }

    .tst-stars {
        display: inline-flex;
        flex-direction: row-reverse;
        gap: 2px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 10px;
        padding: 0.5rem 0.75rem;
    }

        .tst-stars input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .tst-stars label {
            font-size: 1.55rem;
            line-height: 1;
            color: rgba(255, 255, 255, 0.18);
            cursor: pointer;
            transition: color 0.15s ease, transform 0.15s ease;
            padding: 2px;
        }

            .tst-stars label:hover,
            .tst-stars label:hover ~ label {
                color: #fcd34d;
                transform: scale(1.08);
            }

        .tst-stars input:checked ~ label {
            color: #fcd34d;
        }

    .tst-rating-hint {
        color: rgba(255, 255, 255, 0.45);
        font-size: 0.86rem;
    }

    /* Gönder butonu */
    .tst-submit {
        grid-column: 1 / -1;
        margin-top: 8px;
        background-color: #a78bfa;
        color: #0d0d0d;
        font-weight: 600;
        font-size: 0.98rem;
        border-radius: 10px;
        padding: 0.9rem 1.5rem;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.25s ease;
    }

        .tst-submit:hover {
            background-color: #c4b5fd;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(167, 139, 250, 0.35);
        }

        .tst-submit:active {
            transform: translateY(0);
        }
</style>

<div class="tst-wrap">
    <div class="tst-card">

        <div class="tst-header">
            <h2 class="tst-title">Değerlendirme Bırakın</h2>
            <p class="tst-subtitle">Birlikte çalıştıysak deneyimlerinizi ve görüşlerinizi paylaşabilirsiniz.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="tst-alert tst-alert-success">
                <span class="material-symbols-outlined">check_circle</span>
                <span>@TempData["SuccessMessage"]</span>
                <button type="button" class="tst-alert-close" onclick="this.parentElement.style.display='none'">&times;</button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="tst-alert tst-alert-error">
                <span class="material-symbols-outlined">error</span>
                <span>@TempData["ErrorMessage"]</span>
                <button type="button" class="tst-alert-close" onclick="this.parentElement.style.display='none'">&times;</button>
            </div>
        }

        <form asp-controller="Testimonial" asp-action="CreateTestimonial" method="post" class="tst-form">

            <div class="tst-field">
                <label class="tst-label">Adınız <span class="tst-required">*</span></label>
                <input type="text" asp-for="FirstName" class="tst-input" placeholder="Örn: Ahmet" required />
            </div>

            <div class="tst-field">
                <label class="tst-label">Soyadınız <span class="tst-required">*</span></label>
                <input type="text" asp-for="LastName" class="tst-input" placeholder="Örn: Yılmaz" required />
            </div>

            <div class="tst-field tst-field-full">
                <label class="tst-label">Unvanınız veya Şirketiniz</label>
                <input type="text" asp-for="Title" class="tst-input" placeholder="Örn: Senior Developer / X Tech Corp." />
            </div>

            <div class="tst-field tst-field-full">
                <label class="tst-label">Puanınız <span class="tst-required">*</span></label>
                <div class="tst-rating-row">
                    <div class="tst-stars">
                        <input type="radio" asp-for="Rating" id="r5" value="5" checked />
                        <label for="r5" title="5/5">★</label>

                        <input type="radio" asp-for="Rating" id="r4" value="4" />
                        <label for="r4" title="4/5">★</label>

                        <input type="radio" asp-for="Rating" id="r3" value="3" />
                        <label for="r3" title="3/5">★</label>

                        <input type="radio" asp-for="Rating" id="r2" value="2" />
                        <label for="r2" title="2/5">★</label>

                        <input type="radio" asp-for="Rating" id="r1" value="1" />
                        <label for="r1" title="1/5">★</label>
                    </div>
                    <span class="tst-rating-hint">Deneyiminize en uygun puanı seçin.</span>
                </div>
            </div>

            <div class="tst-field tst-field-full">
                <label class="tst-label">Görüşleriniz / Yorumunuz <span class="tst-required">*</span></label>
                <textarea asp-for="Comment" rows="4" class="tst-textarea" placeholder="Proje süreci, iletişim ve çalışma kalitesi hakkındaki düşünceleriniz..." required></textarea>
            </div>

            <button type="submit" class="tst-submit">
                <span class="material-symbols-outlined" style="font-size:1.15rem;">send</span>
                <span>Referans Gönder</span>
            </button>

        </form>

    </div>
</div>
