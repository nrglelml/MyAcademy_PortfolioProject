@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />
<div class="mb-stack-lg">
    <p class="text-on-surface-variant font-body-sm mt-1">Genel bakış ve son hareketler</p>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-md mb-stack-lg">

    <div class="glass-card rounded-xl p-md flex items-center gap-md">
        <div class="w-11 h-11 rounded-lg bg-primary/15 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">folder_open</span>
        </div>
        <div>
            <p class="font-label-sm text-label-sm text-on-surface-variant">Projeler</p>
            <p class="font-headline-sm text-headline-sm text-on-background font-bold">@Model.TotalProjects</p>
        </div>
    </div>

    <div class="glass-card rounded-xl p-md flex items-center gap-md">
        <div class="w-11 h-11 rounded-lg bg-primary/15 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">stacks</span>
        </div>
        <div>
            <p class="font-label-sm text-label-sm text-on-surface-variant">Teknolojiler</p>
            <p class="font-headline-sm text-headline-sm text-on-background font-bold">@Model.TotalTechStacks</p>
        </div>
    </div>

    <div class="glass-card rounded-xl p-md flex items-center gap-md">
        <div class="w-11 h-11 rounded-lg bg-primary/15 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">mail</span>
        </div>
        <div>
            <p class="font-label-sm text-label-sm text-on-surface-variant">Mesajlar</p>
            <p class="font-headline-sm text-headline-sm text-on-background font-bold">@Model.TotalMessages</p>
        </div>
    </div>

    <div class="glass-card rounded-xl p-md flex items-center gap-md">
        <div class="w-11 h-11 rounded-lg bg-primary/15 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">star_rate</span>
        </div>
        <div>
            <p class="font-label-sm text-label-sm text-on-surface-variant">Referanslar</p>
            <p class="font-headline-sm text-headline-sm text-on-background font-bold">@Model.TotalTestimonials</p>
        </div>
    </div>

</div>

<div class="glass-card rounded-xl p-md">
    <div class="flex items-center justify-between mb-md">
        <h2 class="font-headline-sm text-headline-sm text-on-background">Son Mesajlar</h2>
        <a asp-controller="Message" asp-action="Index" class="font-label-sm text-label-sm text-primary hover:underline">Tümünü Gör</a>
    </div>

    @if (!Model.RecentMessages.Any())
    {
        <p class="text-on-surface-variant font-body-sm py-md">Henüz mesaj yok.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-outline-variant">
                        <th class="py-2 pr-4 font-label-sm text-label-sm text-on-surface-variant">Gönderen</th>
                        <th class="py-2 pr-4 font-label-sm text-label-sm text-on-surface-variant">E-Posta</th>
                        <th class="py-2 font-label-sm text-label-sm text-on-surface-variant">Mesaj</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model.RecentMessages)
                    {
                        <tr class="border-b border-outline-variant/50">
                            <td class="py-3 pr-4 font-body-sm text-on-background whitespace-nowrap">@msg.Name</td>
                            <td class="py-3 pr-4 font-body-sm text-on-surface-variant whitespace-nowrap">@msg.Email</td>
                            <td class="py-3 font-body-sm text-on-surface-variant truncate max-w-[300px]">@msg.MessageBody</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>