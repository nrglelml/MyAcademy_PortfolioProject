@model ContactInfo
@{
    ViewData["Title"] = "İletişim Bilgileri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />

<section class="col-span-12 lg:col-span-12">

    @if (Model != null)
    {
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl custom-shadow overflow-hidden">
            
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container text-on-surface-variant border-b border-outline-variant">


                            <th class="px-lg py-md font-label-sm uppercase tracking-wider">Email</th>
                            <th class="px-lg py-md font-label-sm uppercase tracking-wider">Adres</th>
                            <th class="px-lg py-md font-label-sm uppercase tracking-wider">Linkedin URL</th>
                            <th class="px-lg py-md font-label-sm uppercase tracking-wider">Github URL</th>
                            <th class="px-lg py-md font-label-sm uppercase tracking-wider text-right">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/30">
                        <tr class="hover:bg-surface-container-lowest/50 transition-colors">
                            <td class="px-lg py-md text-on-surface-variant">@Model.Email</td>
                            <td class="px-lg py-md text-on-surface-variant">@Model.Address</td>
                            <td class="px-lg py-md text-on-surface-variant">@Model.LinkedinURL</td>
                            <td class="px-lg py-md text-on-surface-variant">@Model.GithubURL</td>
                            <td class="px-lg py-md text-right">
                                <div class="flex justify-end gap-sm">
                                    <a class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-md transition-all" href="/Admin/ContactInfo/UpdateContactInfo/@Model.Id">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <a class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error-container/20 rounded-md transition-all" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?')" href="/Admin/ContactInfo/DeleteContactInfo/@Model.Id">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
           
        </div>
    }
    else
    {
        <div class="alert alert-info"><strong>Henüz İletişim Bilgisi Eklenmemiş</strong></div>

        <br />

        <a class="btn btn-outline-dark" href="/Admin/ContactInfo/CreateContactInfo">Yeni İletişim Bilgisi Ekle</a>
    }



</section>