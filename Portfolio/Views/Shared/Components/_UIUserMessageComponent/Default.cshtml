@*
  Default view for the UIUserMessageComponent. This view is used to display user messages in the UI.
*@

<div class="glass-card p-stack-lg rounded-xl">
    <form id="messageForm" class="flex flex-col gap-stack-md" method="post" asp-action="SendMessage" asp-controller="Default">
        <div>
            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-2" for="name">İsim</label>
            <input class="w-full bg-surface-variant/50 border border-outline-variant rounded-md px-4 py-3 text-on-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="name" placeholder="John Doe" type="text" name="Name" required />
        </div>
        <div>
            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-2" for="email">Email</label>
            <input class="w-full bg-surface-variant/50 border border-outline-variant rounded-md px-4 py-3 text-on-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="email" placeholder="john@example.com" type="email" name="Email" required />
        </div>
        <div>
            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-2" for="message">Mesaj</label>
            <textarea class="w-full bg-surface-variant/50 border border-outline-variant rounded-md px-4 py-3 text-on-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all min-h-[150px]" id="message" name="MessageBody" placeholder="Projeniz hakkında bilgi verin..." required></textarea>
        </div>
        <button class="w-full px-8 py-4 bg-primary text-on-primary rounded-DEFAULT font-label-sm text-label-sm hover:opacity-90 transition-opacity mt-2" type="submit" id="sendMessageBtn">Mesaj Gönderin</button>
    </form>
</div>

<script>
    document.getElementById("messageForm").addEventListener("submit", async function (event) {
        event.preventDefault();

        const form = event.target;
        const btn = document.getElementById("sendMessageBtn");
        const formData = new FormData(form);

        btn.disabled = true;
        btn.textContent = "Gönderiliyor...";

        try {
            const response = await fetch(form.action, {
                method: "POST",
                body: formData
            });

            if (response.ok) {
                await Swal.fire({
                    title: "Mesajınız Gönderildi",
                    text: "Size en kısa sürede dönüş yapılacaktır.",
                    icon: "success",
                    confirmButtonColor: "#3085d6",
                    confirmButtonText: "Tamam!",
                });
                form.reset();
            } else {
                await Swal.fire({
                    title: "Bir Şeyler Ters Gitti",
                    text: "Mesajınız gönderilemedi, lütfen tekrar deneyin.",
                    icon: "error",
                    confirmButtonColor: "#d33",
                    confirmButtonText: "Tamam",
                });
            }
        } catch (err) {
            await Swal.fire({
                title: "Bağlantı Hatası",
                text: "Sunucuya ulaşılamadı, internet bağlantınızı kontrol edin.",
                icon: "error",
                confirmButtonColor: "#d33",
                confirmButtonText: "Tamam",
            });
        } finally {
            btn.disabled = false;
            btn.textContent = "Mesaj Gönderin";
        }
    });
</script>