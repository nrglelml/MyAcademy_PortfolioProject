@*
  Default view for the UIUserMessageComponent. This view is used to display user messages in the UI.
*@

<div class="glass-card p-stack-lg rounded-xl">

    <form id="messageForm" class="flex flex-col gap-stack-md" method="post" asp-action="SendMessage" asp-controller="Default" onsubmit="sendMessage(event)">
        <div>
            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-2" for="name">İsim</label>
            <input class="w-full bg-surface-variant/50 border border-outline-variant rounded-md px-4 py-3 text-on-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="name" placeholder="John Doe" type="text" name="Name"/>
        </div>
        <div>
            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-2" for="email">Email</label>
            <input class="w-full bg-surface-variant/50 border border-outline-variant rounded-md px-4 py-3 text-on-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="email" placeholder="john@example.com" type="email" name="Email"/>
        </div>
        <div>
            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-2" for="message">Mesaj</label>
<textarea class="w-full bg-surface-variant/50 border border-outline-variant rounded-md px-4 py-3 text-on-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all min-h-[150px]" id="message" name="MessageBody" placeholder="Projeniz hakkında bilgi verin..."></textarea>
        </div>
        <button class="w-full px-8 py-4 bg-primary text-on-primary rounded-DEFAULT font-label-sm text-label-sm hover:opacity-90 transition-opacity mt-2" type="submit" >Mesaj Gönderin</button>
    </form>
</div>
<script>
        function sendMessage(event) {
        // Formun sunucuya hemen gitmesini (sayfa yenilenmesini) engeller
        event.preventDefault();

        Swal.fire({
            title: "Mesajınız Gönderildi",
            text: "Size en kısa sürede dönüş yapılacaktır.",
            icon: "success",
            confirmButtonColor: "#3085d6",
            confirmButtonText: "Tamam!",
        }).then((result) => {
            if (result.isConfirmed) {
                // SweetAlert onaylandıktan sonra formu gerçekten sunucuya POST ederiz
                document.getElementById("messageForm").submit();
            }
        });
    }
</script>