@* 
    Admin Layout Sidebar
*@

<aside class="w-sidebar-width h-screen fixed left-0 top-0 bg-surface-lowest border-r border-outline-variant flex flex-col py-lg z-50">
    <div class="px-md mb-xl shrink-0">
        <h2 class="font-h2 text-h2 font-bold text-primary">Admin Paneli</h2>
        <p class="text-on-surface-variant font-label-sm mt-xs">Yönetim Sayfası</p>
    </div>

    <nav class="flex-1 min-h-0 overflow-y-auto space-y-1 px-0">
        <!-- Dashboard (Inactive) -->
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/Dashboard/">
            <span class="material-symbols-outlined">dashboard</span>
            <span class="font-label-md text-label-md">Dashboard</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer " href="/Admin/Banner/">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">home</span>
            <span class="font-label-md text-label-md font-semibold">Banner</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer " href="/Admin/Project/">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">folder_open</span>
            <span class="font-label-md text-label-md font-semibold">Projeler</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer " href="/Admin/TechStack/">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">stacks</span>
            <span class="font-label-md text-label-md font-semibold">Teknolojiler</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer " href="/Admin/ProjectTechStack/">
            <span class="material-symbols-outlined">html</span>
            <span class="font-label-md text-label-md">Projelerdeki Teknolojiler</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/About/">
            <span class="material-symbols-outlined">article_person</span>
            <span class="font-label-md text-label-md">Hakkımızda</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/Education/">
            <span class="material-symbols-outlined">school</span>
            <span class="font-label-md text-label-md">Eğitimlerim</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/Experience/">
            <span class="material-symbols-outlined">laptop_windows</span>
            <span class="font-label-md text-label-md">Deneyimlerim</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/Service/">
            <span class="material-symbols-outlined">design_services</span>
            <span class="font-label-md text-label-md">Servislerim</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/Skills/">
            <span class="material-symbols-outlined">build</span>
            <span class="font-label-md text-label-md">Yeteneklerim</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/Message">
            <span class="material-symbols-outlined">mail</span>
            <span class="font-label-md text-label-md">Gelen Mesajlar</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/ContactInfo">
            <span class="material-symbols-outlined">contact_phone</span>
            <span class="font-label-md text-label-md">İletişim Bilgileri</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/AdminTestimonial/">
            <span class="material-symbols-outlined">star_rate</span>
            <span class="font-label-md text-label-md">Referanslar</span>
        </a>
        <a class="flex items-center gap-md px-md py-sm text-on-surface-variant hover:bg-surface-container-highest transition-colors duration-200 cursor-pointer active:opacity-80" href="/Admin/Settings/">
            <span class="material-symbols-outlined">settings</span>
            <span class="font-label-md text-label-md">Ayarlar</span>
        </a>
    </nav>

    <div class="mt-auto px-md flex items-center gap-md pt-lg border-t border-outline-variant shrink-0">
        @{
            var fullName = User.FindFirst("fullName")?.Value ?? "Admin";
            var imageUrl = User.FindFirst("imageUrl")?.Value;
        }
        <img class="w-10 h-10 rounded-full object-cover"
             src="@(string.IsNullOrEmpty(imageUrl) ? "/avatar.png" : imageUrl)"
             alt="@fullName" />
        <div>
            <p class="font-label-md text-label-md font-bold text-on-surface">@fullName</p>
            <p class="text-[10px] text-on-surface-variant uppercase tracking-wider font-semibold">Süper Admin</p>
        </div>
    </div>
</aside>