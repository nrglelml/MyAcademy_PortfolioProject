@*
   _AdminLayoutNavbar
*@
@{
    var fullName = User.FindFirst("fullName")?.Value ?? "Admin";
    var imageUrl = User.FindFirst("imageUrl")?.Value;
}

<header class="h-16 fixed top-0 right-0 w-[calc(100%-260px)] bg-surface border-b border-outline-variant shadow-sm z-40 flex justify-between items-center px-lg">

    <div class="flex items-center gap-md flex-1">
        <form class="relative w-64" method="get" asp-controller="Project" asp-action="Index">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">search</span>
            <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg py-1.5 pl-10 pr-4 text-body-md focus:ring-2 focus:ring-primary-container focus:border-primary outline-none transition-all"
                   placeholder="Proje ara..." type="text" name="q" />
        </form>
    </div>

    <div class="flex items-center gap-lg">
        <button class="relative p-2 rounded-full hover:bg-surface-container transition-all">
            <span class="material-symbols-outlined text-on-surface">notifications</span>
            <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border-2 border-surface"></span>
        </button>

        <div class="relative">
            <button type="button" id="adminMenuBtn"
                    class="flex items-center gap-sm cursor-pointer hover:bg-surface-container p-1 rounded-lg transition-all">
                <img class="w-8 h-8 rounded-full border border-outline-variant object-cover"
                     src="@(string.IsNullOrEmpty(imageUrl) ? "/images/default-avatar.png" : imageUrl)"
                     alt="@fullName" />
                <span class="font-label-sm text-label-sm text-on-surface hidden md:inline">@fullName</span>
                <span class="material-symbols-outlined text-on-surface-variant">expand_more</span>
            </button>

            <div id="adminMenuDropdown"
                 class="hidden absolute right-0 mt-2 w-48 bg-surface border border-outline-variant rounded-lg shadow-lg py-1 z-50">
                <div class="px-4 py-2 border-b border-outline-variant">
                    <p class="font-label-md text-label-md font-semibold text-on-surface truncate">@fullName</p>
                    <p class="text-[11px] text-on-surface-variant">Süper Admin</p>
                </div>
                <a asp-controller="Auth" asp-action="Logout"
                   class="flex items-center gap-2 px-4 py-2 text-on-surface hover:bg-surface-container-highest transition-colors text-body-md">
                    <span class="material-symbols-outlined text-[18px]">logout</span>
                    Çıkış Yap
                </a>
            </div>
        </div>
    </div>
</header>

<script>
    (function () {
        const btn = document.getElementById("adminMenuBtn");
        const dropdown = document.getElementById("adminMenuDropdown");

        btn.addEventListener("click", function (e) {
            e.stopPropagation();
            dropdown.classList.toggle("hidden");
        });

        document.addEventListener("click", function (e) {
            if (!dropdown.contains(e.target) && !btn.contains(e.target)) {
                dropdown.classList.add("hidden");
            }
        });
    })();
</script>