@model About?
@if (Model == null)
{
    <section class="relative min-h-[921px] flex items-center justify-center px-gutter" id="about">
        <p class="font-body-lg text-body-lg text-on-surface-variant">Hakkımda içeriği bulunamadı.</p>
    </section>
}
else
{

    <section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative bg-surface-container-lowest" id="about">
        <div class="max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-2 gap-stack-lg items-center">
            <div class="relative w-full aspect-square rounded-xl overflow-hidden glass-card">
                <img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" data-alt="Professional portrait of a software engineer in a modern workspace" src="@Model.ImageUrl" />
            </div>
            <div class="flex flex-col gap-stack-md">
                <h2 class="font-headline-md text-headline-md text-on-background">Hakkımda</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">@Model.Title</p>
                <p class="font-body-md text-body-md text-on-surface-variant">@Model.Description</p>
                <div class="grid grid-cols-2 gap-stack-md mt-stack-sm">
                    <div>
                        <h4 class="font-label-sm text-label-sm text-primary mb-1">Frontend</h4>
                        <p class="font-body-md text-body-md text-on-surface-variant">
                            @(string.IsNullOrEmpty(ViewBag.FrontendTechs) ? "Belirtilmemiş" : ViewBag.FrontendTechs)
                        </p>
                    </div>
                    <div>
                        <h4 class="font-label-sm text-label-sm text-primary mb-1">Backend</h4>
                        <p class="font-body-md text-body-md text-on-surface-variant">
                            @(string.IsNullOrEmpty(ViewBag.BackendTechs) ? "Belirtilmemiş" : ViewBag.BackendTechs)
                        </p>
                    </div>
                    <div>
                        <h4 class="font-label-sm text-label-sm text-primary mb-1">Database</h4>
                        <p class="font-body-md text-body-md text-on-surface-variant">
                            @(string.IsNullOrEmpty(ViewBag.DatabaseTechs) ? "Belirtilmemiş" : ViewBag.DatabaseTechs)
                        </p>
                    </div>
                    <div class="flex flex-col gap-stack-md">
                        <h3 class="font-headline-sm text-headline-sm text-on-background">Yeteneklerim</h3>
                        @await Component.InvokeAsync("_UISkillComponent")
                    </div>
                </div>
            </div>
        </div>
    </section>
}

