    <style>
        .glass-card {
            background: rgba(30, 30, 30, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .text-gradient {
            background: linear-gradient(to right, #c0c1ff, #8083ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .glow-accent {
            position: absolute;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(192,193,255,0.15) 0%, rgba(16,20,21,0) 70%);
            border-radius: 50%;
            z-index: 0;
            pointer-events: none;
        }

        /* Hide scrollbar for slider */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="bg-background text-on-background antialiased selection:bg-primary/30 selection:text-primary">
    <!-- TopNavBar -->
    <nav class="bg-background/80 dark:bg-background/80 backdrop-blur-xl border-b border-outline-variant/10 fixed top-0 w-full z-50">
        <div class="flex justify-between items-center max-w-[1200px] mx-auto px-gutter h-20">
            <a class="font-headline-md text-headline-md font-extrabold tracking-tighter text-on-background dark:text-on-background cursor-pointer active:scale-95" href="#">ALEX.DEV</a>
            <div class="hidden md:flex items-center gap-stack-lg">
                <a class="text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors duration-300 font-body-md text-body-md" href="#about">About</a>
                <a class="text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors duration-300 font-body-md text-body-md" href="#services">Services</a>
                <a class="text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors duration-300 font-body-md text-body-md" href="#portfolio">Portfolio</a>
                <a class="text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors duration-300 font-body-md text-body-md" href="#experience">Experience</a>
                <a class="text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors duration-300 font-body-md text-body-md" href="#contact">Contact</a>
            </div>
            <a class="hidden md:inline-flex items-center justify-center px-6 py-3 bg-primary text-on-primary rounded-DEFAULT font-label-sm text-label-sm hover:opacity-90 transition-opacity cursor-pointer active:scale-95" href="#contact">Let's Talk</a>
            <!-- Mobile Menu Button -->
            <button class="md:hidden text-on-background">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">menu</span>
            </button>
        </div>
    </nav>
    <main class="pt-20">
      @RenderBody()
        <!-- Footer -->
        <footer class="bg-surface-container-lowest dark:bg-surface-container-lowest border-t border-outline-variant/10 w-full py-section-padding-mobile md:py-section-padding-desktop">
            <div class="max-w-[1200px] mx-auto px-gutter flex flex-col md:flex-row justify-between items-center gap-stack-md">
                <span class="font-headline-md text-headline-md text-on-surface">ALEX.DEV</span>
                <p class="font-label-sm text-label-sm text-on-surface-variant">© 2024 Alex Dev. Built with Precision.</p>
                <div class="flex gap-stack-md">
                    <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary transition-all opacity-80 hover:opacity-100" href="#">LinkedIn</a>
                    <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary transition-all opacity-80 hover:opacity-100" href="#">GitHub</a>
                    <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary transition-all opacity-80 hover:opacity-100" href="#">Dribbble</a>
                    <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary transition-all opacity-80 hover:opacity-100" href="#">Twitter</a>
                </div>
            </div>
        </footer>
    </main>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const slider = document.getElementById('slider-container');
            const prevBtn = document.getElementById('prev-btn');
            const nextBtn = document.getElementById('next-btn');

            if(slider && prevBtn && nextBtn) {
                const getScrollAmount = () => {
                    const card = slider.querySelector('.snap-center');
                    if (!card) return 0;
                    const cardWidth = card.offsetWidth;
                    const gap = parseFloat(getComputedStyle(slider).gap) || 0;
                    return cardWidth + gap;
                };

                prevBtn.addEventListener('click', () => {
                    slider.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
                });

                nextBtn.addEventListener('click', () => {
                    slider.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
                });
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>