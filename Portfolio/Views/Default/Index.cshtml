
@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<!-- Hero Section -->
@await Component.InvokeAsync("_UIBannerComponent")
<!-- About Section -->
@await Component.InvokeAsync("_UIAboutComponent")
<!-- Experience & Education Section -->
<section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative" id="experience">
    <div class="max-w-container-max mx-auto">
        <div class="text-center mb-stack-lg">
            <h2 class="font-headline-md text-headline-md text-on-background">Özgeçmişim</h2>
            <p class="font-body-md text-body-md text-on-surface-variant mt-2">Profesyonel ve akademik yolculuğum.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
            <!-- Experience -->
            @await Component.InvokeAsync("_UIExperienceComponent")
            <!-- Education -->
            @await Component.InvokeAsync("_UIEducationComponent")
        </div>
    </div>
</section>
<!-- Services Section -->
@await Component.InvokeAsync("_UIServiceComponent")
<!-- Project Slider Section -->
@await Component.InvokeAsync("_UIProjectComponent")
<!-- Testimonials Section -->
@await Component.InvokeAsync("_UITestimonialComponent")
<!-- Contact Section -->
<section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative bg-surface-container-lowest" id="contact">
    <div class="max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-stack-lg">
        @await Component.InvokeAsync("_UIContactInfoComponent")
        @await Component.InvokeAsync("_UIUserMessageComponent")  
    </div>
</section>