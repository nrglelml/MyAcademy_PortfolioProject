@model Banner
@{
    ViewData["Title"] = "Yeni Banner Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>Yeni Banner Ekle</h2>
    <hr />

    <form method="post" action="/Admin/Banner/CreateBanner" enctype="multipart/form-data">
        <div class="mb-3">
            <label class="form-label fw-bold">Başlık</label>
            <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Öne Çıkan Başlık" required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Banner Görseli</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" required />
            <small class="text-muted">Lütfen geçerli bir görsel seçiniz (.jpg, .png, .webp).</small>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Açıklama</label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Banner için kısa bir alt açıklama yazın..."></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <span class="material-symbols-outlined align-middle fs-6">save</span> Kaydet
            </button>
            <a href="/Admin/Banner/Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>