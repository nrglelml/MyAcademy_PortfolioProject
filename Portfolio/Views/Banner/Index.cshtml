@model Banner
@{
    ViewData["Title"] = "Banner Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Banner Bilgisi</h2>

        @if (Model == null)
        {
            <a href="/Admin/Banner/CreateBanner" class="btn btn-outline-dark">
                <span class="material-symbols-outlined align-middle fs-6">add</span> Yeni Banner Ekle
            </a>
        }
    </div>
    <hr />

    @if (Model != null)
    {
        <!-- Banner Bilgi Kartı / Tablosu -->
        <div class="card shadow-sm border-outline-variant">
            <div class="card-body p-0">
                <table class="table table-bordered align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 120px;" class="text-center">Görsel</th>
                            <th style="width: 30%;">Başlık</th>
                            <th>Açıklama</th>
                            <th style="width: 160px;" class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="@Model.ImageUrl" alt="@Model.Title" class="rounded border" style="height: 60px; width: 60px; object-fit: cover;" />
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Görsel Yok</span>
                                }
                            </td>
                            <td class="fw-bold">@(Model.Title ?? "-")</td>
                            <td>@(Model.Description ?? "-")</td>
                            <td class="text-center">
                                <a href="/Admin/Banner/UpdateBanner/@Model.Id" class="btn btn-outline-info btn-sm">
                                    <span class="material-symbols-outlined align-middle fs-6">edit</span> Güncelle
                                </a>
                                <button onclick="deleteBanner(@Model.Id)" class="btn btn-outline-danger btn-sm">
                                    <span class="material-symbols-outlined align-middle fs-6">delete</span> Sil
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center py-4 my-3" role="alert">
            <span class="material-symbols-outlined fs-1 text-warning mb-2">warning</span>
            <h5 class="alert-heading">Henüz bir Banner bilgisi eklenmemiş!</h5>
            <p class="mb-3">Sitenizin karşılama alanını oluşturmak için lütfen yeni bir banner bilgisi ekleyin.</p>
            <a href="/Admin/Banner/CreateBanner" class="btn btn-dark">
                <span class="material-symbols-outlined align-middle fs-6">add</span> Oluştur
            </a>
        </div>
    }
</div>

<script>
    function deleteBanner(id) {
        if (!id) return;

        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            confirmButtonText: "Evet, Sil!",
            cancelButtonText: "İptal",
            cancelButtonColor: "#d33",
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Banner/DeleteBanner/" + id;
            }
        });
    }
</script>