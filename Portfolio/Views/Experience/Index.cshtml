@model List<Experience>
@{
    ViewData["Title"] = "Deneyim Bilgilerim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<table class="table table-hover table table-bordered">
    <tr>

        <th>Başlık</th>
        <th>Şirket</th>
        <th>Açıklama</th>
        <th>Tarih</th>
        <th>İşlemler</th>

    </tr>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Company</td>
                <td>@item.Description</td>
                <td>
                    @item.StarYear - @(item.EndYear == null ? "Devam Ediyor" : item.EndYear)
                </td>
                <td>
                    <button onclick="deleteExperience(@item.Id)" class="btn btn-outline-danger">Sil</button>
                    <a href="/Admin/Experience/UpdateExperience/@item.Id" class="btn btn-outline-info">Güncelle</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="/Admin/Experience/CreateExperience/" class="btn btn-outline-dark">Yeni Deneyim Bilgisi Ekle</a>

<script>
    function deleteExperience(id){

            Swal.fire({
      title: "Silmek istediğinize emin misiniz?",
      text: "Bu işlemi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      confirmButtonText: "Evet, Sil!",
      cancelButtonText: "İptal",
      cancelButtonColor: "#d33",
    }).then((result) => {
      if (result.isConfirmed)
      window.location.href = "/Admin/Experience/DeleteExperience/"+id;
    });
    }
</script>