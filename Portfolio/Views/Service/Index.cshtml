@model List<Service>
@{
    ViewData["Title"] = "Servislerim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container-fluid mt-4">
    <h2>Servis Listesi</h2>
    <hr />

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 20%;">Başlık</th>
                <th style="width: 15%;" class="text-center">İkon</th>
                <th>Açıklama</th>
                <th style="width: 18%;" class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.Title</td>

                    <td class="text-center">
                        <div class="d-flex align-items-center justify-content-center gap-2">
                            <span class="material-symbols-outlined fs-3 text-primary">
                                @item.Icon
                            </span>
                            <small class="text-muted">(@item.Icon)</small>
                        </div>
                    </td>

                    <td>@item.Description</td>
                    <td class="text-center">
                        <button onclick="deleteService(@item.Id)" class="btn btn-outline-danger btn-sm">Sil</button>
                        <a href="/Admin/Service/UpdateService/@item.Id" class="btn btn-outline-info btn-sm">Güncelle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a href="/Admin/Service/CreateService" class="btn btn-outline-dark">
        <span class="material-symbols-outlined align-middle fs-6">add</span> Yeni Servis Ekle
    </a>
</div>

<script>
    function deleteService(id) {
        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            confirmButtonText: "Evet, Sil!",
            cancelButtonText: "İptal",
            cancelButtonColor: "#d33",
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Service/DeleteService/" + id;
            }
        });
    }
</script>