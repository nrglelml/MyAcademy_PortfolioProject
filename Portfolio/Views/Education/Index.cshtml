@model List<Education>
@{
    ViewData["Title"] = "Eğitim Bilgilerim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<table class="table table-hover table table-bordered">
    <tr>

        <th>Okul Adı</th>
        <th>Bölüm</th>
        <th>Açıklama</th>
        <th>Ortalama</th>
        <th>Tarih</th>
        <th>İşlemler</th>

    </tr>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SchoolName</td>
                <td>@item.Department</td>
                <td>@item.Description</td>
                <td> @item.GPA</td>
                <td>
                    @item.StarYear - @(item.GradationYear == null ? "Devam Ediyor" : item.GradationYear)
                </td>
                <td>
                    <button onclick="deleteEducation(@item.Id)" class="btn btn-outline-danger">Sil</button>
                    <a href="/Admin/Education/UpdateEducation/@item.Id" class="btn btn-outline-info">Güncelle</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="/Admin/Education/CreateEducation/" class="btn btn-outline-dark">Yeni Eğitim Bilgisi Ekle</a>

<script>
    function deleteEducation(id){

            Swal.fire({
      title: "Silmek istediğinize emin misiniz?",
      text: "Bu işlemi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      confirmButtonText: "Evet, Sil!",
      cancelButtonText: "İptal",
      cancelButtonColor: "#d33",
    }).then((result) => {
      if (result.isConfirmed)
      window.location.href = "/Admin/Education/DeleteEducation/"+id;
    });
    }
</script>