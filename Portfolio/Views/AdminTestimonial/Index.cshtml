@model List<Testimonial>
@{
    ViewData["Title"] = "Referanslar & Değerlendirmeler";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var testimonials = Model ?? new List<Testimonial>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Gelen Referanslar ve Yorumlar</h2>
        <span class="badge bg-primary fs-6">Toplam: @testimonials.Count Kayıt</span>
    </div>
    <hr />

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 70px;" class="text-center">Profil</th>
                <th style="width: 18%;">Ad Soyad</th>
                <th style="width: 18%;">Unvan / Şirket</th>
                <th style="width: 120px;" class="text-center">Puan</th>
                <th>Yorum</th>
                <th style="width: 100px;" class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (testimonials.Any())
            {
                @foreach (var item in testimonials)
                {
                    <tr>
                        <td class="text-center">
                            <div class="rounded-circle bg-dark text-white fw-bold d-flex align-items-center justify-content-center mx-auto" style="width: 40px; height: 40px; font-size: 14px;">
                                @(string.IsNullOrEmpty(item.Initials) ? "??" : item.Initials)
                            </div>
                        </td>

                        <td class="fw-bold">@item.FirstName @item.LastName</td>

                        <td class="text-muted">@(item.Title ?? "-")</td>

                        <td class="text-center text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= item.Rating)
                                {
                                    <span class="material-symbols-outlined fs-6" style="font-variation-settings: 'FILL' 1;">star</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined fs-6 text-secondary" style="font-variation-settings: 'FILL' 0;">star</span>
                                }
                            }
                        </td>

                        <td>
                            <p class="mb-0 text-break" style="font-size: 0.95rem;">@item.Comment</p>
                        </td>

                        <td class="text-center">
                            <button onclick="deleteTestimonial(@item.Id)" class="btn btn-outline-danger btn-sm" title="Sil">
                                <span class="material-symbols-outlined align-middle fs-6">delete</span>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        <div class="d-flex flex-column align-items-center gap-2">
                            <span class="material-symbols-outlined fs-1 text-secondary">rate_review</span>
                            <span>Henüz hiç referans veya değerlendirme bulunmuyor.</span>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function deleteTestimonial(id) {
        if (!id) return;

        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu referans yorumunu kalıcı olarak silmek üzeresiniz!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            confirmButtonText: "Evet, Sil!",
            cancelButtonText: "İptal",
            cancelButtonColor: "#3085d6",
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/AdminTestimonial/DeleteTestimonial/" + id;
            }
        });
    }
</script>