@model About
@{
    ViewData["Title"] = "Hakkımda";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />

<section class="col-span-12 lg:col-span-12">

    @if (Model != null)
    {
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl custom-shadow overflow-hidden">
          
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container text-on-surface-variant border-b border-outline-variant">


                            <th class="px-lg py-md font-label-sm uppercase tracking-wider">Başlık</th>
                            <th class="px-lg py-md font-label-sm uppercase tracking-wider">Açıklama</th>
                            <th class="px-lg py-md font-label-sm uppercase tracking-wider text-right">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/30">
                        <tr class="hover:bg-surface-container-lowest/50 transition-colors">
                            <td class="px-lg py-md">
                                <div class="flex items-center gap-md">
                                    <img class="w-10 h-10 rounded-lg object-cover border border-outline-variant" data-alt="@Model.Title" src="@Model.ImageUrl" />
                                    <span class="font-label-md text-on-surface">@Model.Title</span>
                                </div>
                            </td>

                            <td class="px-lg py-md text-on-surface-variant">@Model.Description</td>

                            <td class="px-lg py-md text-right">
                                <div class="flex justify-end gap-sm">
                                    <a class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-md transition-all"href="/Admin/About/UpdateAbout/@Model.Id">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <a class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error-container/20 rounded-md transition-all" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?')" href="/Admin/About/DeleteAbout/@Model.Id">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
           
        </div>
    }
    else
    {
        <div class="alert alert-info"><strong>Henüz Hakkımızda Bilgisi Eklenmemiş</strong></div>

        <br />

        <a class="btn btn-outline-dark" href="/Admin/About/CreateAbout">Yeni Hakkımda Ekle</a>
    }



</section>