@model About
@{
    ViewData["Title"] = "Yeni Hakkımda Bilgisi Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>Yeni Hakkımda Bilgisi Ekle</h2>
    <hr />

    <form method="post" action="/Admin/About/CreateAbout" enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label fw-bold">Başlık</label>
            <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Ben Kimim?" required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Açıklama</label>
            <textarea rows="5" asp-for="Description" class="form-control" placeholder="Hakkınızda detaylı bilgi giriniz..." required></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Görsel Seçin</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" required />
            <small class="text-muted">Lütfen geçerli bir resim dosyası (.jpg, .png, .webp) seçiniz.</small>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-outline-dark">
                <span class="material-symbols-outlined align-middle fs-6">save</span> Kaydet
            </button>
            <a href="/Admin/About/Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>